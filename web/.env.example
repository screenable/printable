# Optional: Supabase-Verbindung zur Build-Zeit festverdrahten.
# Sind beide gesetzt, entfällt das Verbindungsformular im Login und es bleibt
# nur die E-Mail/Passwort-Anmeldung. Nach Vite-Konvention müssen die Variablen
# mit VITE_ beginnen, damit sie im Client-Bundle landen.
#
# WICHTIG: Immer den oeffentlichen anon-Key verwenden, niemals den service-Key.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=ey...
