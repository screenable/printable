# ── Pflicht ────────────────────────────────────────────────────────────────
# Eindeutige Geräte-ID dieser Box (entspricht devices.id in Supabase)
DEVICE_ID=box-edeka-nord-01
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=YOUR_ANON_OR_DEVICE_KEY

# ── Optional: Laufzeit-Verhalten ─────────────────────────────────────────────
ENVIRONMENT=production
PORT=3000
# Lokaler Offline-Store (Gutscheine, Job-Queue, Config-Cache)
DATA_DIR=./data
# Abgleich-Intervall mit Supabase (ms)
SYNC_INTERVAL_MS=30000

# ── Optional: Defaults, falls devices.config noch nicht geladen wurde ─────────
# Diese Werte gelten nur beim allerersten Boot / offline. Danach kommt alles
# aus Supabase (devices.config), einstellbar über die Generator-Webseite.
PRINTER_HOST=192.168.100.200
PRINTER_PORT=9100
GPIO_PIN=17
DEBOUNCE_MS=10
GPIO_BUZZER_LED_PIN=5
NEOPIXEL_COUNT=0
NEOPIXEL_GPIO=18
NEOPIXEL_BRIGHTNESS=80
LED_DONE_HOLD_MS=2200
LED_ERROR_HOLD_MS=3000
WEBHOOK_COOLDOWN_MS=1000
WLED_IP=192.168.1.100

# ── Optional: Self-Update (Abschnitt 4 des Konzepts) ─────────────────────────
GITHUB_OWNER=screenable
GITHUB_REPO=printable
# Nur nötig für private Repos
GITHUB_TOKEN=
# true = Box wendet devices.desired_version automatisch an (systemd startet neu)
AUTO_UPDATE_APPLY=false
