ENVIRONMENT=development
PORT=3000
SUPABASE_URL=https:
SUPABASE_KEY=ABC
DEBOUNCE_MS=10
GPIO_PIN=17
VOUCHER_API_BASE_URL=https://api.screenable.io
VOUCHER_API_KEY=YOUR_API_KEY_HERE
WLED_IP=192.168.1.100
# Auto-update configuration
# Enable automatic checking for new releases at application startup
GITHUB_OWNER=screenable
GITHUB_REPO=printable
# GITHUB_TOKEN: Optional - only required for private repositories
# Generate a Personal Access Token at https://github.com/settings/tokens with 'repo' scope
# For public repositories, leave empty or omit this variable
GITHUB_TOKEN=ghp_your_github_token_here
AUTO_UPDATE_ENABLED=true
# AUTO_UPDATE_APPLY: Set to 'true' to automatically apply updates (will restart app)
AUTO_UPDATE_APPLY=false